{
  "name": "opshield",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "description": "OpShield - Central platform layer for the Redbay product suite (auth, billing, provisioning)",
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "test:unit": "turbo test:unit",
    "test:integration": "turbo test:integration",
    "test:e2e": "pnpm --filter @opshield/frontend test:e2e",
    "test:watch": "turbo test:watch",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "format": "prettier --write \"**/*.{ts,tsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,css,md}\"",
    "type-check": "turbo type-check",
    "clean": "turbo clean && rm -rf node_modules",
    "db:generate": "pnpm --filter @opshield/backend db:generate",
    "db:push": "pnpm --filter @opshield/backend db:push",
    "db:migrate": "pnpm --filter @opshield/backend db:migrate",
    "db:studio": "pnpm --filter @opshield/backend db:studio",
    "db:seed": "pnpm --filter @opshield/backend db:seed",
    "db:reset": "pnpm --filter @opshield/backend db:reset"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "eslint": "^9.28.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.8.19",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
